{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "PolarChat",
  "version": "0.2.0",
  "identifier": "com.polarchat.desktop",
  "build": {
    "frontendDist": "../client/dist",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:client",
    "beforeDevCommand": "npm run dev:client"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "PolarChat",
        "width": 1280,
        "height": 800,
        "minWidth": 940,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:3001 ws://localhost:3001; style-src 'self' 'unsafe-inline'; script-src 'self'"
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "tooltip": "PolarChat - Private & Secure"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "resources": {
      "../server/dist/**": "server/dist/",
      "../server/node_modules/**": "server/node_modules/",
      "../server/package.json": "server/"
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": null
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libjavascriptcoregtk-4.1-0"]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://github.com/sambulbo-ship-it/Polarchat/releases/latest/download/latest.json"
      ]
    }
  }
}
