<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Allow the app to be run on macOS -->
    <key>com.apple.security.app-sandbox</key>
    <true/>

    <!-- Network access for WebSocket/API communication -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Local network server (embedded backend) -->
    <key>com.apple.security.network.server</key>
    <true/>

    <!-- Microphone access for voice chat -->
    <key>com.apple.security.device.audio-input</key>
    <true/>

    <!-- Allow JIT for V8 (Electron requirement) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- Allow unsigned executable memory (Electron requirement) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
</dict>
</plist>
